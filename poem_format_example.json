{
  "title": "鹿鸣",
  "text": [
    ["呦呦鹿鸣，食野之苹。", "我有嘉宾，鼓瑟吹笙。"],
    ["吹笙鼓簧，承筐是将。", "人之好我，示我周行。"],
    ["呦呦鹿鸣，食野之蒿。", "我有嘉宾，德音孔昭。"],
    ["视民不恌，君子是则是效。", "我有旨酒，嘉宾式燕以敖。"],
    ["呦呦鹿鸣，食野之芩。", "我有嘉宾，鼓瑟鼓琴。"],
    ["鼓瑟鼓琴，和乐且湛。", "我有旨酒，以燕乐嘉宾之心。"]
  ],
  "annotations": {
    "呦": "yōu",
    "笙": "shēng",
    "簧": "huáng",
    "恌": "tiāo",
    "燕": "yàn",
    "敖": "áo",
    "芩": "qín",
    "湛": "dān"
  },
  "notes": "宴饮宾客之诗。以鹿鸣食苹起兴，表达主人宴请嘉宾的热忱。"
}
