[
  {
    "name": "北山之什",
    "poems": [
      {
        "title": "北山",
        "text": [
          [
            "陟彼北山，言采其杞。",
            "偕偕士子，朝夕从事。",
            "王事靡盬，忧我父母。"
          ],
          [
            "溥天之下，莫非王土。",
            "率土之滨，莫非王臣。",
            "大夫不均，我从事独贤。"
          ],
          [
            "四牡彭彭，王事傍傍。",
            "嘉我未老，鲜我方将。",
            "旅力方刚，经营四方。"
          ],
          [
            "或燕燕居息，或尽瘁事国。",
            "或息偃在床，或不已于行。"
          ],
          [
            "或不知叫号，或惨惨劬劳。",
            "或栖迟偃仰，或王事鞅掌。"
          ],
          [
            "或湛乐饮酒，或惨惨畏咎。",
            "或出入风议，或靡事不为。"
          ]
        ],
        "annotations": {
          "盬": "gǔ",
          "溥": "pǔ",
          "劬": "qú",
          "鞅": "yāng",
          "湛": "dān",
          "咎": "jiù"
        },
        "notes": "大夫刺幽王役使不均之作，诗人感叹天下土地皆王土、臣民皆王臣，却只有自己被迫劳苦奔波，而他人安逸享乐，表达了愤懑不平之情。"
      },
      {
        "title": "无将大车",
        "text": [
          [
            "无将大车，祇自尘兮。",
            "无思百忧，祇自疧兮。"
          ],
          [
            "无将大车，维尘冥冥。",
            "无思百忧，不出于熲。"
          ],
          [
            "无将大车，维尘雝兮。",
            "无思百忧，祇自重兮。"
          ]
        ],
        "annotations": {
          "将": "jiāng",
