          ],
          [
            "鼓钟喈喈，淮水湝湝。",
            "忧心且悲。",
            "淑人君子，其德不回。"
          ],
          [
            "鼓钟伐鼛，淮有三洲。",
            "忧心且妯。",
            "淑人君子，其德不犹。"
          ],
          [
            "鼓钟钦钦，鼓瑟鼓琴。",
            "笙磬同音。",
            "以雅以南，以龠不偕。"
          ]
