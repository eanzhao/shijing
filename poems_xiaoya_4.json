            "啸歌伤怀，念彼硕人。"
          ],
          [
            "樵彼桑薪，卬烘于煁。",
            "维彼硕人，实劳我心。"
          ],
          [
            "鼓钟于宫，声闻于外。",
            "念子懆懆，视我迈迈。"
          ],
          [
            "有鹙在梁，有鹤在林。",
            "维彼硕人，实劳我心。"
          ],
          [
            "鸳鸯在梁，戢其左翼。",
            "之子无良，二三其德。"
          ],
          [
            "有扁斯石，履之卑兮。",
            "之子之远，俾我疧兮。"
          ]
